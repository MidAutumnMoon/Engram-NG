{
  "name": "sillytavern-extension-engram",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview",
    "format": "deno fmt",
    "prettify": "deno fmt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:types": "deno run -A scripts/bundle_vendor_types.ts",
    "lint": "deno fmt --check && deno lint && oxlint src -D correctness -W perf -W suspicious",
    "lint:fix": "oxlint src -D correctness -W perf -W suspicious --fix",
    "knip": "knip"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "fast-json-patch": "^3.1.1",
    "immer": "^10.1.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.18.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@deno/vite-plugin": "^2.0.2",
    "@tailwindcss/postcss": "^4.2.3",
    "@tailwindcss/vite": "^4.2.3",
    "@types/jquery": "^4.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/toastr": "^2.1.43",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "fake-indexeddb": "^6.2.5",
    "knip": "^5.82.1",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.3",
    "type-fest": "^5.7.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.9",
    "vitest": "^4.0.0"
  }
}
